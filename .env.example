# ─────────────────────────────────────────────────────────────
#  AcademIQ — Environment Variables
#  Copy this file:  cp .env.example .env
#  Fill in every value before running the server.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-char-hex-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Supabase ─────────────────────────────────────────────────
# Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic ────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Resend (Email) ────────────────────────────────────────────
# resend.com → API Keys  |  Must verify sender domain first
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@yourdomain.com
RESEND_FROM_NAME=AcademIQ Alerts

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated. Include your Vercel URL + localhost for dev.
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# ── Risk Thresholds ───────────────────────────────────────────
RISK_RED_THRESHOLD=70
RISK_AMBER_THRESHOLD=45
